# iKuai Router Management Skill - Configuration Example
# Copy this file to .env and fill in your actual values

# API Credentials (Get from https://open.ikuai8.com)
IKUAI_APP_ID=your_app_id_here
IKUAI_APP_SECRET=your_app_secret_here

# Default Device ID (The router you want to manage)
IKUAI_DEV_ID=your_device_id_here

# API Version (2.x or 3.x)
IKUAI_API_VERSION=2.x

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=ikuai_skill.log

# Monitor Configuration
MONITOR_INTERVAL=60
MONITOR_CPU_THRESHOLD=90
MONITOR_MEMORY_THRESHOLD=90
MONITOR_TEMP_THRESHOLD=75

# Alert Configuration
ENABLE_ALERTS=true
ALERT_WEBHOOK_URL=https://your-webhook-url.com/ikuai-alerts

# VPN Configuration (Optional)
VPN_PORT=1194
VPN_PROTOCOL=UDP
VPN_SUBNET=10.8.0.0
VPN_SUBNET_MASK=255.255.255.0

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_REQUESTS_PER_HOUR=1000

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1
RETRY_BACKOFF=2
